<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Editor.ViewModels"
             xmlns:controls="using:Editor.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Editor.Views.EditorView"
             x:DataType="vm:EditorViewModel">
    <Grid Background="{Binding BackgroundColor, Converter={StaticResource RgbaColorToBrushConverter}}">
        <controls:SkPanel Renderer="{Binding}" MouseHandler="{Binding}" />
    </Grid>
</UserControl>
