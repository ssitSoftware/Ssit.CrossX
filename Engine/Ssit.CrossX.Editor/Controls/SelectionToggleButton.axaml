<UserControl
    Padding="0"
    x:Class="Ssit.CrtossX.Editor.Controls.SelectionToggleButton"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:i="clr-namespace:Projektanker.Icons.Avalonia;assembly=Projektanker.Icons.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ToggleButton
        Click="Button_OnClick"
        Content="{Binding #Root.Text}"
        FontFamily="{Binding #Root.FontFamily}"
        FontSize="{Binding #Root.FontSize}"
        FontStyle="{Binding #Root.FontStyle}"
        FontWeight="{Binding #Root.FontWeight}"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        i:Attached.Icon="{Binding #Root.Icon}"
        x:Name="Button" />
</UserControl>
