<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Ssit.CrossX.Editor.Panels.TilesetSelector"
    x:DataType="viewModels:MainViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:controls="clr-namespace:Ssit.CrossX.Editor.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:Ssit.CrossX.Editor.Helpers"
    xmlns:i="https://github.com/projektanker/icons.avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:Ssit.CrossX.Editor.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        Background="#101010"
        ClipToBounds="True"
        RowDefinitions="Auto, 1, *">

        <Grid
            Background="{DynamicResource ControlBackground}"
            ColumnDefinitions="*, Auto"
            Grid.Row="0"
            Margin="0,0,0,2">

            <ComboBox
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                ItemsSource="{Binding TilesetsContainer.TileSets}"
                Margin="4,5,4,5"
                SelectedItem="{Binding TilesetSelectorViewModel.SelectedTileset}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="helpers:Tileset">
                        <Label Content="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                Margin="4,5,4,5"
                Orientation="Horizontal"
                Spacing="4">

                <TextBlock Text="{Binding TilesetSelectorViewModel.SelectedTiles}"
                           VerticalAlignment="Center"/>
                
                <ToggleButton
                    Classes="Toolbar"
                    IsChecked="{Binding TilesetSelectorViewModel.ShowGrid}"
                    ToolTip.Tip="Show grid"
                    i:Attached.Icon="mdi-grid" />

                <Label
                    Classes="Toolbar"
                    Content="{Binding TilesetSelectorViewModel.Zoom.Info}"
                    HorizontalContentAlignment="Right"
                    Width="50" />

                <Button
                    Classes="Toolbar"
                    Command="{Binding TilesetSelectorViewModel.Zoom.ZoomInCommand}"
                    HotKey="{x:Static helpers:HotKeys.TilesetZoomIn}"
                    ToolTip.Tip="Zoom In"
                    i:Attached.Icon="mdi-magnify-plus-outline" />

                <Button
                    Classes="Toolbar"
                    Command="{Binding TilesetSelectorViewModel.Zoom.ZoomOutCommand}"
                    HotKey="{x:Static helpers:HotKeys.TilesetZoomOut}"
                    ToolTip.Tip="Zoom Out"
                    i:Attached.Icon="mdi-magnify-minus-outline" />
                
            </StackPanel>
        </Grid>

        <ScrollViewer
            Background="{StaticResource EmptyBackground}"
            Grid.Row="2"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Visible">
            <controls:SkPanel
                Background="{StaticResource TilesBackground}"
                ContinuousRedraw="False"
                HorizontalAlignment="Left"
                Margin="8,0,16,16"
                MouseHandler="{Binding TilesetSelectorViewModel}"
                Renderer="{Binding TilesetSelectorViewModel}"
                VerticalAlignment="Top" />
        </ScrollViewer>

    </Grid>

</UserControl>
