<?xml version="1.0" encoding="utf-8"?>
<Dialogs Name="Merchant">
    
    <!-- Player meets Merchant for the first time --> 
    <Dialog>
        <Text>Hello wanderer.|What's your name?
            <Option>{playerName}
                <Text>Ah, {playerName}. Nice one!|What brings you here {playerName}?
                    <Option>None of your business, old man!
                        <Text>No need to be rude, young one!|Good bye!
                            <Option Set="metMerchantRude">Bye</Option>
                        </Text>
                    </Option>
                    <Option>I am looking for someone...
                        <Text>Ah, you're looking for a friend
                            <Option>He's not my friend...
                                <Text>I see... you may try in the old inn|in the southern part of the camp.
                                    <Option>...
                                        <Text>There are many people out there.
                                            <Option Set="metMerchant">Thanks!</Option>
                                        </Text>
                                    </Option>
                                </Text>
                            </Option>
                        </Text>
                    </Option>
                </Text>
            </Option>
        </Text>
    </Dialog>

    <!-- Player talks to Merchant after being rude to him -->
    <Dialog On="metMerchantRude" Highlight="True">
        <Text>Ah, the rude one!|Any more bitter words for an old man?
            <Option>No, bye!</Option>
            <Option>I am very sorry sir! I really need your help...
                <Text>...
                    <Option>I am looking for someone...
                        <Text>Hmm....|A friend perhaps?
                            <Option>I don't think so...
                                <Text>Try the old inn in the southern|part of the camp. Many people out there...
                                    <Option>Thank you and sorry again!
                                        <Text>Off you go, youndling (chuckles)|What was your name again?
                                            <Option>{playerName}
                                                <Text>{playerName}...|See you later {playerName}.
                                                    <Option Set="metMerchant">Bye!</Option>
                                                </Text>
                                            </Option>
                                        </Text>
                                    </Option>
                                </Text>
                            </Option>
                        </Text>
                    </Option>
                </Text>
            </Option>    
                
        </Text>
    </Dialog>

    <!-- Regular talk after the introduction -->
    <Dialog On="metMerchant">
        <Text>Hello {playerName} friend! Wanna buy anything?
            <Option>No, thank you</Option>
            <Option Action="showMerchantStore">Yes</Option>
            <Option>How are you today?
                <Text>I am great! Thanks for asking!
                    <Option>That's great! Can I buy anything?
                        <Text>Yes, yes my friend!
                            <Option Action="showMerchantStore">...</Option>
                        </Text>
                    </Option>
                    <Option>That's nice to hear. See ya!</Option>
                </Text>
            </Option>
        </Text>
    </Dialog>
</Dialogs>