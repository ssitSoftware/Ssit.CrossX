<?xml version="1.0" encoding="utf-8"?>
<Dialogs Name="Merchant" DefaultLanguage="en">
    
    <!-- Player meets Merchant for the first time --> 
    <Dialog>
        <Text>  <en>Hello wanderer.|What's your name?</en>
                <pl>Witaj wędrowcze.|Jak cię zwą?</pl>
            
            <Option>  <en>{playerName}</en>
                
                <Text>  <en>Ah, {playerName}. Nice one!|What brings you here {playerName}?</en>
                        <pl>O, {playerName}. Całkiem ładnie!|Co cię tutaj sprowadza {playerName}?</pl>
                    
                    <Option>  <en>None of your business, old man!</en>
                              <pl>Nie twój interes staruchu!</pl>
                        
                        <Text>  <en>No need to be rude, young one!|Good bye!</en>
                                <pl>I po co to chamstwo?|Żegnam...</pl>
                            
                            <Option Set="metMerchantRude">  <en>Bye</en>
                                                            <pl>Nara!</pl>
                            </Option>
                        </Text>
                    </Option>
                    
                    <Option>  <en>I am looking for someone...</en>
                              <pl>Szukam kogoś...</pl>
                        
                        <Text>  <en>Ah, you're looking for a friend</en>
                                <pl>O, szukasz przyjaciela?</pl>
                            
                            <Option>  <en>He's not my friend...</en>
                                      <pl>Nie jest moim przyjacielem...</pl>
                                
                                <Text>  <en>I see... you may try in the old inn|in the southern part of the camp.</en>
                                        <pl>Rozumiem... możesz spróbować w starej|gospodzie na południu obozu.</pl>
                                    
                                    <Option>  <en>...</en>
                                        
                                        <Text>  <en>There are many people out there.</en>
                                                <pl>Dużo osób się tam przewija.</pl>
                                            
                                            <Option Set="metMerchant">  <en>Thanks!</en>
                                                                        <pl>Dzięki!</pl>
                                            </Option>
                                        </Text>
                                    </Option>
                                </Text>
                            </Option>
                        </Text>
                    </Option>
                </Text>
            </Option>
        </Text>
    </Dialog>

    <!-- Player talks to Merchant after being rude to him -->
    <Dialog On="metMerchantRude" Highlight="True">
        <Text>  <en>Ah, the rude one!|Any more bitter words for an old man?</en>
                <pl>O, chamski wrócił!|Jeszcze jakieś złośliwości dla starego człowieka?</pl>
            
            <Option>  <en>No, bye!</en>
                      <pl>Nie, nara!</pl>
            </Option>
            
            <Option>  <en>I am very sorry sir! I really need your help...</en>
                      <pl>Przepraszam za tamto! Potrzebuję pomocy...</pl>
                
                <Text>  <en>...</en>
                    
                    <Option>  <en>I am looking for someone...</en>
                              <pl>Szukam kogoś...</pl>
                        
                        <Text>  <en>Hmm....|A friend perhaps?</en>
                                <pl>Hmm....|Przyjaciela?</pl>
                                
                            <Option>  <en>I don't think so...</en>
                                      <pl>Nie, raczej nie...</pl>
                                
                                <Text>  <en>Try the old inn in the southern|part of the camp. Many people out there...</en>
                                        <pl>Zobacz w starej gospodzie na południu obozu.|Przechodzi tamtędy wielu ludzi...</pl>
                                    
                                    <Option>  <en>Thank you and sorry again!</en>
                                              <pl>Dziękuję i jeszcze raz przepraszam!</pl>
                                        
                                        <Text>  <en>Off you go, youndling|...(chuckles)...</en>
                                                <pl>Dobra, spadaj młodziku|...(śmieje się)...</pl>
                                            
                                            <Option>  <en>...</en>
                                                
                                                <Text>  <en>What was your name again?</en>
                                                        <pl>Jak to cię zwali?</pl>
                                                    
                                                    <Option>  <en>{playerName}</en>en>
                                                        
                                                        <Text>  <en>{playerName}...|See you later {playerName}.</en>
                                                                <pl>{playerName}...|Do zobaczenia {playerName}.</pl> 
                                                            
                                                            <Option Set="metMerchant">  <en>Bye!</en>
                                                                                        <pl>Do zobaczenia!</pl>
                                                            </Option>
                                                        </Text>
                                                    </Option>
                                                </Text>
                                            </Option>
                                        </Text>
                                    </Option>
                                </Text>
                            </Option>
                        </Text>
                    </Option>
                </Text>
            </Option>
                
        </Text>
    </Dialog>

    <!-- Regular talk after the introduction -->
    <Dialog On="metMerchant">
        <Text>  <en>Hello {playerName} friend! Wanna buy anything?</en>
                <pl>Witaj {playerName}, przyjacielu! Kupujesz coś?</pl>
            
            <Option Action="showMerchantStore"> <en>Yes</en>
                                                <pl>Tak</pl>
            </Option>
            
            <Option>    <en>No, thank you</en>
                        <pl>Nie, dziękuję</pl>
            </Option>
            
            <Option>    <en>How are you today?</en>
                        <pl>Witaj, jak się dziś czujesz?</pl>
                
                <Text>  <en>I am great! Thanks for asking!</en>
                        <pl>Świetnie! Dzięki, że pytasz!</pl>
                    
                    <Option>    <en>That's great! Can I buy anything?</en>
                                <pl>To super! Mogę coś kupić?</pl>
                        
                        <Text>  <en>Yes, yes my friend!</en>
                                <pl>Tak, pewnie kolego!</pl>
                            
                            <Option Action="showMerchantStore"> <en>...</en>
                            </Option>
                            
                        </Text>
                    </Option>
                    <Option>    <en>That's nice to hear. See ya!</en>
                                <pl>Dobrze to słyszeć. Do zobaczenia!</pl>
                    </Option>
                </Text>
            </Option>
        </Text>
    </Dialog>
</Dialogs>