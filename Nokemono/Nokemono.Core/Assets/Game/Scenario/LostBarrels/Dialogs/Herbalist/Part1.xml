<?xml version="1.0" encoding="utf-8"?>
<Dialogs Name="Herbalist" DefaultLanguage="pl">
    <Dialog Highlight="True">
        <Text>
            <pl>Witaj dziecko. Jak się czujesz?</pl>

            <Option>
                <pl>Dobrze, gdzie ja jestem?</pl>

                <Text>
                    <pl>U mnie w domu pod lasem. Znalazłam cię nieprzytomną tam w górze strumienia.</pl>

                    <Option>
                        <pl>Kim jesteś?</pl>

                        <Text>
                            <pl>Jestem tylko prostą zielarką, która uciekła od smrodu miasta.</pl>

                            <Option Set="HerbalistIntroduction">
                                <pl>...</pl>
                            </Option>
                        </Text>
                    </Option>
                </Text>
            </Option>

            <Option>
                <pl>Kim jesteś?</pl>

                <Text>
                    <pl>Zielarką, która nienawidzi smrodu miasta.</pl>

                    <Option Set="HerbalistIntroduction">
                        <pl>...</pl>
                    </Option>
                </Text>
            </Option>
        </Text>
    </Dialog>

    <Dialog Highlight="True" On="HerbalistIntroduction">
        <Text>
            <pl>Hmm?</pl>

            <Option>
                <pl>Czy widziałaś gdzieś moją broń?</pl>

                <Text>
                    <pl>Broń? Oj nie, ja nie dotykam takich rzeczy. Gdy cię znalazłam leżałaś prawie naga na trawie pod drzewem.</pl>

                    <Option Set="HerbalistAskWeapon">
                        <pl>O nie...</pl>
                    </Option>

                    <Option>
                        <pl>I nie widziałaś mieczy ani rewolwerów?</pl>
                        <Text>
                            <pl>Na Światłość, kim ty jesteś dziewczyno?</pl>

                            <Option>
                                <pl>Jestem z zakonu rewolwerowców. Potrzebuję mojej broni!</pl>

                                <Text>
                                    <pl>Rewolwerowiec tutaj? Cóż za dziwny zbieg okoliczności…|Przykro mi dziecko, ale nie widziałam żadnej broni.</pl>

                                    <Option set="HerbalistGunslingerIntro">
                                        <pl>Muszę jej poszukać!</pl>
                                    </Option>
                                </Text>
                            </Option>
                        </Text>
                    </Option>
                </Text>
            </Option>
            
            <Option>
                <pl>Gdzie schowałaś moją broń kobieto?</pl>
                
                <Text>
                    <pl>Słucham? Dziecko, ja się takich rzeczy nie tykam. Nie miałaś ze sobą żadnej broni.</pl>
                    
                    <Option>
                        <pl>Jesteś pewna?</pl>
                        
                        <Text>
                            <pl>Oczywiście. Gdy cię znalazłam leżałaś prawie naga na trawie pod drzewem.</pl>
                            
                            <Option Set="HerbalistAskWeapon">
                                <pl>O nie...</pl>
                            </Option>
                        </Text>
                    </Option>
                    
                    <Option>
                        <pl>Kłamiesz!</pl>
                        <Text>
                            <pl>Dziecko, nie bądź niewdzięczna! Przyjęłam cię pod swój dach i się tobą zajęłam, gdy byłaś nieprzytomna.</pl>
                            
                            <Option>
                                <pl>...</pl>
                                
                                <Text>
                                    <pl>Poza tym po co mi jakakolwiek broń? Jestem zielarką.</pl>
                                    
                                    <Option Set="HerbalistAskWeapon">
                                        <pl>Masz rację, przepraszam.</pl>
                                    </Option>
                                </Text>
                            </Option>
                        </Text>
                    </Option>
                </Text>
            </Option>
        </Text>
    </Dialog>

    <Dialog Highlight="True" On="HerbalistAskWeapon">
        
        <Text>
            <pl>A tak w ogóle to kim ty jesteś, że nosisz ze sobą broń?</pl>
            
            <Option>
                <pl>Jestem z zakonu rewolwerowców.</pl>
                
                <Text>
                    <pl>Rewolwerowiec tutaj? Cóż za dziwny zbieg okoliczności…</pl>
                    
                    <Option Set="HerbalistGunslingerIntro">
                        <pl>...</pl>
                    </Option>
                </Text>
            </Option>
        </Text>
    </Dialog>
    
    <Dialog Highlight="True" On="HerbalistGunslingerIntro">
        
        <Text>
            <pl>Tak sobie myślę, że mogłabyś poszukać w okolicach strumienia pod wielkim drzewem</pl>
            
            <Option>
                <pl>Dlaczego?</pl>
                
                <Text>
                    <pl>Tam cię znalazłam. Jest tam wiele rozpadlin i zarośli.</pl>
                    
                    <Option Set="FindWeapon.TaskStarted">
                        <pl>Idę!</pl>
                    </Option>
                </Text>
            </Option>
        </Text>
        
    </Dialog>
    
    <Dialog On="FindWeapon.TaskStarted">
        <Text>
            <pl>Znalazłaś już swoją broń?</pl>
            
            <Option>
                <pl>Jeszcze nie...</pl>
            </Option>
        </Text>
    </Dialog>

    <Dialog On="FindWeapon.TaskCompleted">
        <Text>
            <pl>Widzę, żę znalazłaś miecze!</pl>

            <Option>
                <pl>Tak, ale nie mogę znaleźć moich rewolwerów!</pl>
                
                <Text>
                    <pl>Przykro mi, nie wiem jak Ci pomóc.</pl>
                    
                    <Option>
                        <pl>Wyruszam do miasta.</pl>
                        
                        <Text>
                            <pl>...</pl>
                        </Text>
                        
                        <Option>
                            <pl>Dziękuję za wszystko!</pl>
                            
                            <Text>
                                <pl>Powodzenia dziecko!|(Będziesz go potrzebować...)</pl>
                                
                                <Option>
                                    <pl>Żegnaj...</pl>
                                    
                                    <Text>
                                        <pl>Kieruj się na wschód.|Żegnaj!</pl>
                                        
                                        <Option Set="HerbalistFarewell">
                                            <pl>...</pl>
                                        </Option>
                                    </Text>
                                </Option>
                            </Text>
                        </Option>
                        
                    </Option>
                </Text>
            </Option>
        </Text>
    </Dialog>
    
    <Dialog On="HerbalistFarewell">
        <Text>
            <pl>Miasto jest na wschodzie.</pl>
            
            <Option>
                <pl>...</pl>
            </Option>
        </Text>
    </Dialog>

</Dialogs>