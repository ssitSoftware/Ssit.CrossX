<?xml version="1.0" encoding="utf-8"?>
<Page ViewModel="MainPageViewModel" Namespace="SampleGame.Game.UI.Pages">

    <xx_Using>Ssit.CrossX.UI</xx_Using>
    <xx_Using>Ssit.CrossX.UI.Views</xx_Using>
    <xx_Using>Ssit.CrossX.UI.Parameters</xx_Using>
    <xx_Using>SampleGame.Game.UI.ViewModels</xx_Using>
    
    <xx_ImportContainer xx_Type="Templates" xx_Name="templates"/>
    
    <Container Padding="({10%}, {10%})">
        <Label xx_Styles="Title, Label" Text="ViewModel.Title" AnchorX="10" AnchorY="10" Width="100" Height="100" HorizontalAlign="Align.Center" VerticalAlign="Align.Start"/>
        <Label xx_Styles="Label" Text="{Hello World!}" AnchorX="10" AnchorY="10" Width="100" Height="100" HorizontalAlign="Align.Center" VerticalAlign="Align.Start"/>
        <ListBox xx_OfType="TestItem" Items="ViewModel.Items" ItemTemplate="templates.TestItemTemplate"/>
    </Container>
</Page>
